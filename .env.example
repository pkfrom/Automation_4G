# 📡 Automation_4G Configuration Template
# คัดลอกไฟล์นี้เป็นชื่อ .env และกำหนดค่าข้อมูลจริงของคุณ
# Copy this file to .env and configure with your actual values

# ─── NMS (Interface Box) ──────────────────────────────────────────────────────
# URL ของระบบ Interface Box (NMS) เช่น http://192.168.1.10
NMS_URL=http://<ip_address>
# ชื่อผู้ใช้ในการเข้าสู่ระบบ NMS (ค่าเริ่มต้น: admin)
NMS_USER=admin
# รหัสผ่านสำหรับการเข้าสู่ระบบ NMS
NMS_PASS=your_secret_password
# โฟลเดอร์สำหรับเก็บไฟล์ CSV ที่ Export ออกมาจากระบบ (ค่าเริ่มต้น: IFBox_Export)
# NMS_EXPORT_DIR=IFBox_Export

# ─── Google Apps Script ───────────────────────────────────────────────────────
# URL ของ Google Apps Script Web App ที่ Deploy สำหรับอัปโหลดข้อมูลเข้า Google Sheets
GAS_UPLOAD_URL=https://script.google.com/macros/s/.../exec

# ─── Telegram Notification ───────────────────────────────────────────────────
# [กลุ่มหลัก / Main Channel] บอตและแชทไอดีสำหรับส่งรายงานสรุปและส่งไฟล์ผลลัพธ์
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=-100123456789

# [ระบบแจ้งเตือนข้อผิดพลาด / Error Alerting] บอตและแชทไอดีสำหรับแจ้งเตือนสถานะความผิดพลาด (Fallback)
NOTIFY_BOT_TOKEN=987654321:XYZabc...
NOTIFY_CHAT_ID=-100987654321
